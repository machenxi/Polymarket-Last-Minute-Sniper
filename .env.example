# =============================================================================
#  POLYMARKET LAST-MINUTE SNIPER  –  .env config
#  Copy to .env and fill in your secrets. Never commit .env to git.
# =============================================================================

# ── WALLET (required) ─────────────────────────────────────────────────────────
# Your Ethereum private key – used to sign Polymarket CLOB orders directly.
# Export from MetaMask: Account Details → Export Private Key
# Format: 64 hex chars, with or without 0x prefix
PRIVATE_KEY=0xyour_private_key_here

# Your Polygon wallet address (must match the private key above)
WALLET_ADDRESS=0xyour_wallet_address_here

# ── SIMMER API (required) ─────────────────────────────────────────────────────
# Simmer handles Polymarket order routing. Get key at https://simmer.markets
SIMMER_API_KEY=your_simmer_api_key_here

# ── TRADING MODE ─────────────────────────────────────────────────────────────
# true  = paper trade, no real money moves
# false = LIVE trading with real funds
DRY_RUN=true

# ── RISK LIMITS ───────────────────────────────────────────────────────────────
MAX_OPEN_POSITIONS=1
DAILY_STOP_LOSS_PCT=0.10    # Stop for the day after 10% bankroll loss
BASE_BET_PCT=0.02           # 2% of bankroll per trade (base)
MAX_BET_PCT=0.05            # 5% of bankroll per trade (max, HIGH signal only)

# ── SIGNAL THRESHOLDS ────────────────────────────────────────────────────────
MIN_MOVE_PCT=0.20           # BTC must move ≥ 0.20% from round open
SUSTAINED_MOVE_SECS=10      # Move must hold for 10 sec before entry
ENTRY_WINDOW_SECS=45        # Only enter in last 45 sec before expiry
YES_MAX_FOR_BUY_YES=0.72    # Don't buy YES if already priced above 0.72
YES_MIN_FOR_BUY_NO=0.30     # Don't buy NO if YES is below 0.30

# ── MARKET FILTERS ────────────────────────────────────────────────────────────
MAX_SPREAD=0.03             # Skip markets with bid-ask spread > $0.03
MIN_LIQUIDITY=50            # Skip markets with less than $50 liquidity
MARKET_WINDOWS=5m,15m       # Which fast-market windows to watch
ASSET=BTC

# ── EXECUTION ────────────────────────────────────────────────────────────────
LIMIT_ORDER_TTL_MS=2000     # Cancel unfilled limit order after 2 sec
AGGRESSIVE_FILL_THRESHOLD=HIGH  # Use market order on HIGH confidence signals
EXIT_BEFORE_EXPIRY_SECS=5   # Force-close open position 5 sec before expiry

# ── MISC ─────────────────────────────────────────────────────────────────────
LOG_LEVEL=info              # trace | debug | info | warn | error | silent
ANALYTICS_FILE=./sniper-trades.jsonl
POLL_INTERVAL_MS=2000
BINANCE_WS_URL=wss://stream.binance.com:9443/ws
BINANCE_SYMBOL=btcusdt
SIMMER_API_BASE=https://api.simmer.markets
